{
  "name": "elite-dashboard",
  "version": "1.3.7",
  "description": "Elite Agency OF Stats Dashboard",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "package": "vite build && electron-builder --win",
    "release": "vite build && electron-builder --win --publish always",
    "release:mac": "vite build && electron-builder --mac --publish always",
    "start": "electron ."
  },
  "build": {
    "appId": "com.eliteagency.dashboard",
    "productName": "Elite Dashboard",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "dist-react/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "identity": "-"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "leif-tech",
      "repo": "elite-dashboard"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "firebase": "^10.14.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
